DATABASE_URL="file:./dev.db"

# ─── AI Provider (set at least one) ───
# Option A: Claude only (recommended for simplicity — no Ollama needed)
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# Option B: Ollama (local, free — requires Docker ollama service)
# OLLAMA_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3"

# If both are set, Ollama is tried first, Claude is fallback.
# If only ANTHROPIC_API_KEY is set, Claude is used directly (no timeout delay).

# ─── Auth (optional — omit to disable) ───
# AUTH_USERS="sarah:mypass,john:mypass"

# ─── Geo Provider (optional, default: osm/free) ───
# GEO_PROVIDER="google"
# GOOGLE_MAPS_API_KEY="AIza..."

# ─── Cron (optional) ───
# CRON_SECRET="your-secret"
